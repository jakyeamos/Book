{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "commonjs",
                            "moduleResolution":  "node",
                            "strict":  true,
                            "esModuleInterop":  true,
                            "forceConsistentCasingInFileNames":  true,
                            "skipLibCheck":  true,
                            "outDir":  ".planning/.tmp-tsrun/platform"
                        },
    "include":  [
                    "platform/**/*.ts",
                    "app/**/*.ts"
                ]
}
